# ─────────────────────────────────────────────────────────────────
# Vercel Environment Variables (set these in the Vercel dashboard)
# Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# Your Render backend URL (get this after deploying to Render)
VITE_API_URL=https://devkalp-api.onrender.com/api/v1

# Your live Razorpay key (from razorpay.com dashboard)
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXX

# Your Vercel deployment URL
VITE_APP_URL=https://devkalp.vercel.app
