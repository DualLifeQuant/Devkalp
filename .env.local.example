# ── Backend API ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Payments ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXX

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Sentry (optional — monitoring) ───────────────────────────────────
# Get from: https://sentry.io → Settings → Projects → DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=your-org
SENTRY_PROJECT=devkalp-frontend
SENTRY_AUTH_TOKEN=

# ── ERPNext Integration (optional) ───────────────────────────────────
# URL of your ERPNext instance (leave empty to disable)
NEXT_PUBLIC_ERP_URL=
# ERPNext API credentials (server-side only — never prefix with NEXT_PUBLIC_)
ERP_API_TOKEN=your_token
ERP_API_KEY=your_key
